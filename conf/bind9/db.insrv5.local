$TTL    604800
@       IN      SOA     ns.insrv5.local. admin.insrv5.local. (
                              2         ; Serial
                         604800         ; Refresh
                          86400         ; Retry
                        2419200         ; Expire
                         604800 )       ; Negative Cache TTL
;
@       IN      NS      ns.insrv5.local.
@       IN      A       192.168.51.100     

; Infraestructura
ns      IN      A       192.168.51.253     
backup	IN		  A		    192.168.51.251         

; Servidores
openldap  IN    A       192.168.51.252
mysql   IN      A       192.168.51.250

; Paneles Internos
pma 		  IN      A       192.168.51.3  
ldapadmin IN      A       192.168.51.4

; Correo interno
@       IN      MX      10 mail.insrv5.local.
mail    IN      A       192.168.51.25
imap    IN      A       192.168.51.25
pop3    IN      A       192.168.51.25